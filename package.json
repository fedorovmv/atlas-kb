{
  "name": "atlas",
  "version": "0.7.0",
  "description": "Atlas is a Markdown-first engineering memory for coding agents. It discovers project structure and connects specifications, design rationale, code and tests.",
  "private": true,
  "type": "module",
  "bin": {
    "atlas": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"fs.cpSync('src/scaffold/templates','dist/scaffold/templates',{recursive:true})\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "atlas": "tsx src/cli.ts",
    "atlas:init": "tsx src/cli.ts init",
    "atlas:validate": "tsx src/cli.ts validate",
    "atlas:recall": "tsx src/cli.ts recall",
    "check": "npm run build && npm run test"
  },
  "keywords": [
    "opencode",
    "memory-bank",
    "frontmatter",
    "coding-agent",
    "markdown"
  ],
  "dependencies": {
    "@opencode-ai/plugin": "^1.17.15",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.18.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
